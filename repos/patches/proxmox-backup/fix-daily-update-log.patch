+static LOGGER: ContainerLogger = ContainerLogger;
+
+struct ContainerLogger;
+
+impl log::Log for ContainerLogger {
+    fn enabled(&self, metadata: &log::Metadata<'_>) -> bool {
+        metadata.level() <= log::Level::Info
+    }
+
+    fn log(&self, record: &log::Record<'_>) {
+        if self.enabled(record.metadata()) {
+            let mut stderr = std::io::stderr().lock();
+            let _ = writeln!(stderr, "{}", record.args());
+        }
+    }
+
+    fn flush(&self) {}
+}
+
+fn init_container_logger() -> Result<(), Error> {
+    let output = OpenOptions::new().write(true).open("/proc/1/fd/1")?;
+    let output_fd = output.as_raw_fd();
+
+    if unsafe { libc::dup2(output_fd, libc::STDOUT_FILENO) } == -1 {
+        return Err(std::io::Error::last_os_error().into());
+    }
+
+    if unsafe { libc::dup2(output_fd, libc::STDERR_FILENO) } == -1 {
+        return Err(std::io::Error::last_os_error().into());
+    }
+
+    log::set_logger(&LOGGER)
+        .map_err(|err| anyhow::format_err!("unable to initialize logger - {err}"))?;
+    log::set_max_level(log::LevelFilter::Info);
+
+    Ok(())
+}
+
 fn main() {
     proxmox_backup::tools::setup_safe_path_env();
 
